#!/bin/bash
lin="LIN_DRIVE"
esp="ESP_DRIVE"
swap="SWAP_DRIVE"


if [ $EUID != 0 ]; then
    sudo "$0" "$@"
    exit $?
fi

umount /mnt
umount LABEL=$esp LABEL=$lin
umount /dev/sdc1 /dev/sdc3
umount /mnt
mkfs.fat -F 32 -n $esp /dev/sdc1
mkfs.btrfs -f -L $lin /dev/sdc3
mkswap -L $swap /dev/sdc2
mount LABEL=$lin /mnt
mount -m LABEL=$esp /mnt/boot

mkdir -p /mnt/home/jason/.packages
mkdir /mnt/shared
mkdir -p /mnt/home/jason/jasorepo

rsync -axHAWXSR --info=progress2 /etc/pacman.d/ /mnt/
rsync -axHAWXSR --info=progress2 /etc/pacman.conf /mnt/

archinstall --advanced --config /home/jason/user_configuration.json --creds /home/jason/user_credentials.json --silent
rsync -axHAWXSR --info=progress2 /etc/pacman.conf /mnt/
rsync -axHAWXSR --info=progress2 /etc/pacman.d/ /mnt/
rsync -axHAWXSR --info=progress2 /usr/bin/makepkg /mnt/
rsync -axHAWXSR --info=progress2 /home/jason/.s3cfg /mnt/
rsync -axHAWXSR --info=progress2 /home/jason/.aws
echo "jason ALL=(ALL:ALL) NOPASSWD: ALL" >> /mnt/etc/sudoers
rm -rf /var/lib/pacman/sync/*
rm -rf /home/jason/jasorepo/jasorepo.*
rm -rf /home/jason/jasorepo/*.sig
chown -R jason /home/jason
chmod -R 777 /home/jason/jasorepo
arch-chroot -u jason /mnt "cd /home/jason/ && git clone https://github.com/coolduderules/jasolinux.git && cd jasolinux/Scripts && echo -ne '1\n' | ./install.sh -drs"


sed -i '$ d' /mnt/etc/sudoers

umount LABEL=$esp LABEL=$lin
umount /dev/sdc1 /dev/sdc3
exit
